{
    "name": "opencode-agent",
    "version": "0.1.0",
    "description": "OpenCode Agent service for cognee-code — wraps @opencode-ai/sdk to provide a local AI coding assistant with cognee MCP tools",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "bun run --hot src/index.ts",
        "build": "tsc -p tsconfig.json",
        "start": "bun run dist/src/index.js",
        "test": "bun test test/",
        "test:unit": "bun test test/sandbox/unit/",
        "test:integration": "bun test test/sandbox/integration/",
        "sandbox:test": "echo '→ use bun run test:unit or test:integration'",
        "typecheck": "tsc --noEmit",
        "router:dev": "bun run src/opencode-router/cli.ts"
    },
    "dependencies": {
        "@e2b/code-interpreter": "^2.4.2",
        "@opencode-ai/plugin": "^1.2.10",
        "@opencode-ai/sdk": "latest",
        "@slack/socket-mode": "^2.0.6",
        "@slack/web-api": "^7.15.1",
        "commander": "^12.1.0",
        "dotenv": "^16.4.7",
        "effect": "4.0.0-beta.48",
        "grammy": "^1.39.3",
        "microsandbox": "^0.4.0",
        "openclaw": "file:./src/opencode-router/shims/openclaw",
        "pino": "^9.6.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/bun": "latest",
        "@types/node": "^22.10.2",
        "tsx": "^4.20.6",
        "typescript": "^5.0.0"
    },
    "trustedDependencies": []
}
